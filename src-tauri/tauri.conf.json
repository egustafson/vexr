{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vexr",
  "version": "0.1.0",
  "identifier": "com.vexr.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray-icon.png"
    },
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "width": 1,
        "height": 1,
        "visible": false
      },
      {
        "label": "set-reminder",
        "url": "set-reminder.html",
        "title": "Set Reminder",
        "width": 480,
        "height": 380,
        "minWidth": 480,
        "minHeight": 380,
        "resizable": false,
        "visible": false,
        "closable": true
      },
      {
        "label": "manage-reminders",
        "url": "manage-reminders.html",
        "title": "Manage Reminders",
        "width": 640,
        "height": 480,
        "minWidth": 560,
        "minHeight": 400,
        "visible": false,
        "closable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
